    old "{#natsuki_exclusive_2_ch3_ef6baab9}"
    new "ناتسوکی دوباره شروع می‌کنه به گریه کردن."

    old "{#natsuki_exclusive_2_ch3_b91f07cb}"
    new "قصد نداشتم رو تو خالی کنم…"

    old "{#natsuki_exclusive_2_ch3_b2ecdb48}"
    new "واقعاً قصد نداشتم!"

    old "{#natsuki_exclusive_2_ch3_3d1f8469}"
    new "م‍… مهم نیست."

    old "{#natsuki_exclusive_2_ch3_06f8103e}"
    new "…چیزی هست که می‌خوای در موردش صحبت کنی؟"

    old "{#natsuki_exclusive_2_ch3_58a33d30}"
    new "ناتسوکی سرش رو به چپ و راست تکون می‌ده."

    old "{#natsuki_exclusive_2_ch3_527e1928}"
    new "فقط…"

    old "{#natsuki_exclusive_2_ch3_9e68e89e}"
    new "هرروز…"

    old "{#natsuki_exclusive_2_ch3_5c7e6955}"
    new "…خیلی… سخته."

    old "{#natsuki_exclusive_2_ch3_403bf723}"
    new "من فقط می‌خوام…"

    old "{#natsuki_exclusive_2_ch3_7f5f52df}"
    new "…بیام به باشگاه و…"

    old "{#natsuki_exclusive_2_ch3_bb2cf764}"
    new "…"

    old "{#natsuki_exclusive_2_ch3_7c82291b}"
    new "ناتسوکی دوباره سکوت می‌کنه."

    old "{#natsuki_exclusive_2_ch3_1f4f8fe8}"
    new "نمی‌تونم زورش کنم؛ پس باید تنها کاری که می‌دونم رو بکنم."

    old "{#natsuki_exclusive_2_ch3_b12907fb}"
    new "باشه…"

    old "{#natsuki_exclusive_2_ch3_0933a463}"
    new "خب، بهت کمک می‌کنم این رو جمع کنی."

    old "{#natsuki_exclusive_2_ch3_a72a892b}"
    new "و بقیه‌ی مانگاها رو برات جابه‌جا می‌کنم."

    old "{#natsuki_exclusive_2_ch3_f2316b97}"
    new "آه."

    old "{#natsuki_exclusive_2_ch3_705c9d7a}"
    new "جلد ۲ دخترهان پارفه رو برمی‌دارم."

    old "{#natsuki_exclusive_2_ch3_a2098188}"
    new "این رو بذاریم کنار."

    old "{#natsuki_exclusive_2_ch3_d5488f86}"
    new "این یه ذره حالت رو بهتر می‌کنه، نه؟"

    old "{#natsuki_exclusive_2_ch3_cbbc612d}"
    new "می‌تونیم وقتی من این‌جا رو جمع کردم شروع کنیم."

    old "{#natsuki_exclusive_2_ch3_09261119}"
    new "ناتسوکی با چشم‌های اشک‌آلود سرش رو می‌آره بالا."

    old "{#natsuki_exclusive_2_ch3_35c0c424}"
    new "لب‌هاش شروع می‌کنه به لرزیدن."

    old "{#natsuki_exclusive_2_ch3_45e4e633}"
    new "تو…"

    old "{#natsuki_exclusive_2_ch3_714ac447}"
    new "تو خیلی به من محبت می‌کنی…"

    old "{#natsuki_exclusive_2_ch3_fb2e5377_2}"
    new "عه؟"

    old "{#natsuki_exclusive_2_ch3_87c8fb04}"
    new "شنیدن این از ناتسوکی عجیب بود."

    old "{#natsuki_exclusive_2_ch3_3ab62f98}"
    new "اصلآً انتظارش رو نداشتم."

    old "{#natsuki_exclusive_2_ch3_c14c584c}"
    new "خب…"

    old "{#natsuki_exclusive_2_ch3_e764e874}"
    new "دوست‌ها همین کار رو می‌کنن، نه؟"

    old "{#natsuki_exclusive_2_ch3_07ed5951}"
    new "نن…"

    old "{#natsuki_exclusive_2_ch3_b2b589da}"
    new "ناتسوکی سرش رو به پایین می‌اندازه و سعی می‌کنه جلوی اشک‌هاش رو بگیره."

    old "{#natsuki_exclusive_2_ch3_8fe0bd7d}"
    new "نمی‌دونم امروز چه اتفاقی براش افتاده؛ ولی حداقل کاری که می‌تونم براش انجام بدم اینه که باهاش مهربون باشم."

    old "{#natsuki_exclusive_2_ch3_a1b548d5}"
    new "چند دقیقه‌ی بعد که من کتاب‌های پخش شده رو جمع می‌کنم، بینمون یه سکوت برقراره."

    old "{#natsuki_exclusive_2_ch3_e59057e2}"
    new "حواسم جمعه که اون‌ها رو به ترتیب بذارم تو جعبهشون."

    old "{#natsuki_exclusive_2_ch3_c3343162}"
    new "بعد از یه مدت، ناتسوکی شروع به کمک کردن می‌کنه."

    old "{#natsuki_exclusive_2_ch3_40d3ec9e}"
    new "چیزی طول نکشید تا کارمون تموم شه، و من جعبه رو روی قفسه‌ای که ناتسوکی می‌خواست، می‌ذارم."

    old "{#natsuki_exclusive_2_ch3_9b6dafb7}"
    new "بعدش، می‌رم روی چارپایه و سریع بقیه‌ی کتاب‌های ناتسوکی رو از قفسه‌ی بالا جابه‌جا می‌کنم."

    old "{#natsuki_exclusive_2_ch3_1ef377da}"
    new "خیلی خب--!"

    old "{#natsuki_exclusive_2_ch3_da95669b}"
    new "دیگه تموم شد."

    old "{#natsuki_exclusive_2_ch3_13d8e7da}"
    new "از چارپایه می‌پرم پایین."

    old "{#natsuki_exclusive_2_ch3_5868bb1a}"
    new "ناتسوکی چشم‌هاش رو از من برمی‌گردونه."

    old "{#natsuki_exclusive_2_ch3_102cdced}"
    new "م‍-ممنون…"

    old "{#natsuki_exclusive_2_ch3_7a59b594}"
    new "هاهاها…"

    old "{#natsuki_exclusive_2_ch3_5d062774}"
    new "کاری نکردم."

    old "{#natsuki_exclusive_2_ch3_5add4c86}"
    new "ناتسوکی جلدی که کنار گذاشته بودم رو تو دست‌هاش گرفته."

    old "{#natsuki_exclusive_2_ch3_cbaa4f78}"
    new "خیلی خب، من آماده‌ام."

    old "{#natsuki_exclusive_2_ch3_1c682213}"
    new "خوبه."

    old "{#natsuki_exclusive_2_ch3_fa0160f8}"
    new "حتیٰ اگه نبودی، زورت می‌کردم."

    old "{#natsuki_exclusive_2_ch3_28001d17}"
    new "تو قراره رو حرفت بایستی."

    old "{#natsuki_exclusive_2_ch3_033c6a89}"
    new "راجع‌به بهتر کردن حالم."

    old "{#natsuki_exclusive_2_ch3_2ad33ed6}"
    new "هرجور شما بخوای!"

    old "{#natsuki_exclusive_2_ch3_22eb0e44}"
    new "ما روی همون جای قبلی می‌شینیم، و من جلد دوم رو باز می‌کنم."

    old "{#natsuki_exclusive_2_ch3_810de178}"
    new "حال ناتسوکی خیلی زود بهتر می‌شه، و به قسمت‌هایی می‌خنده و برام بهشون اشاره می‌کنه."

    old "{#natsuki_exclusive_2_ch3_98c65fde}"
    new "ناتسوکی فوق‌العاده تند و تیزه، و به کلی جوک و عناصر پس‌زمینه‌ای تکرار شده اشاره می‌کنه."

    old "{#natsuki_exclusive_2_ch3_3a9320da}"
    new "آخر سر، من از اینکه همه چیز این مانگا با هم ارتباط داشتن خیلی خوشم اومد."

    old "{#natsuki_exclusive_2_ch3_91c88c35}"
    new "مثل اینکه ناتسوکی واقعاً خوش سلیقه بود."

    old "{#natsuki_exclusive_2_ch3_db9deb6e}"
    new "بعد از یه مدت، مونیکا عین همیشه توجهمون رو جلب می‌کنه، و وقتشه که دوباره شعرهامون رو به هم نشون بدیم."

    old "{#natsuki_exclusive_2_ch3_b32d5756}"
    new "پس این فعلاً دست من می‌مونه."

    old "{#natsuki_exclusive_2_ch3_a910372f}"
    new "بعله!"

    old "{#natsuki_exclusive_2_ch3_0ad75efb}"
    new "این‌دفعه با اشتیاق بیشتری داری می‌گی."

    old "{#natsuki_exclusive_2_ch3_d556a490}"
    new "خب، دیگه دارم کم کم بهش علاقه‌مند می‌شم، می‌دونی."

    old "{#natsuki_exclusive_2_ch3_e36e39a2}"
    new "هههه."

    old "{#natsuki_exclusive_2_ch3_3e76d6fe}"
    new "بهت گفته بودم."

    old "{#natsuki_exclusive_2_ch3_e9ea92f3}"
    new "آره، آره…"

    old "{#natsuki_exclusive_2_ch3_7d10c262}"
    new "به صندلی‌ام برمی‌گردم و کتاب رو می‌ذارم تو کیفم."
