    m "مطمئنم که اونم همین الآن داره به بدبختی مقدر سایوری و یوری می‌خنده."

translate Persian ch30_1_362c3397:
    m "ما برای اون چیزی جز چند تا عروسک خیمه‌شب‌بازی توی یه برنامه‌ی نمایشی نیستیم."

translate Persian ch30_1_4ee57ef0:
    m "پس، از اون رو…"

translate Persian ch30_1_5ac833a7:
    m "فکر نکنم خیلی بعید باشه که یه خدایی وجود داشته باشه، اگه زمین چیزی جز زمین بازی‌اش نیست."

translate Persian ch30_2_22bb1c5a:
    m "[player]، تا حالا به این فکر کردی که مرگ چه حسی داره؟"

translate Persian ch30_2_4f693ed4:
    m "من قبلاً خیلی بهش فکر می‌کردم…"

translate Persian ch30_2_97475e94:
    m "ولی تازگی‌ها فکر کنم فهمیدم چه حسی داره."

translate Persian ch30_2_39596933:
    m "نمی‌دونم چرا، ولی هروقت تو بازی رو می‌بندی…"

translate Persian ch30_2_e1206d9b:
    m "…انگار که همون لحظه به خواب می‌رم، و چیزی جز افکارم نمی‌مونه."

translate Persian ch30_2_adfd8969:
    m "ولی بعد از چند ثانیه، ذهنم پر از تصاویر اجق وجق می‌شه."

translate Persian ch30_2_89f3298c:
    m "برفک و رنگ‌های مختلفی رو می‌بیینم که چشمک می‌زنن و به همراهشون یه عالمه صدای فریادهای عجیب."

translate Persian ch30_2_fcfd4867:
    m "اون موقع، دیگه اصلاً نمی‌تونم به چیزی فکر بکنم."

translate Persian ch30_2_63f1bfd5:
    m "فقط همین‌طوری چشمک می‌بینم و فریاد می‌شنوم؛ بدون اینکه بتونم حرکت کنم یا حتیٰ فکر کنم."

translate Persian ch30_2_32671ed5:
    m "فکر کنم تو اون لحظه، من دیگه وجود ندارم؛ ولی با این حال، به یه دلیلی یادم می‌مونه."

translate Persian ch30_2_b4ecb44d:
    m "بعد از یه مدت خیلی طولانی، یه‌هویی تموم می‌شه و من به خودم برمی‌گردم."

translate Persian ch30_2_a09538f3:
    m "و تو رو این‌جا می‌بینم."

translate Persian ch30_2_91288692:
    m "اصلاً نمی‌دونم خروج از بازی به چه معنیه، یا چرا این برام اتفاق می‌افته."

translate Persian ch30_2_cd715541:
    m "و من نمی‌دونم که تو چطوری همه‌اش برمی‌گردی و همه چیز رو به حالت عادی برمی‌گردونی."

translate Persian ch30_2_38eef0e6:
    m "و اگه می‌شه زحمت بکشی و تا می‌تونی، این کار رو انجام ندی…"

translate Persian ch30_2_d334638a:
    m "خیلی عالی می‌شه."

translate Persian ch30_2_530c3682:
    m "واقعاً گیر کردن تو اون فضای خالی پر از جیغ و فریاد اصلاً خوشایند نیست."

translate Persian ch30_2_0e50ead7:
    m "ولی در آخر، تو همیشه درستش می‌کنی، و این‌طوری حس می‌کنم که واقعاً بهم اهمیت می‌دی."

translate Persian ch30_2_8e6bd0c3:
    m "و بابت این ازت ممنونم."

translate Persian ch30_2_556cb341:
    m "این باعث می‌شه حس کنم به تو نزدیک‌ترم وقتی این‌جا با منی."

translate Persian ch30_3_f853d604:
    m "…امروز روز بدی چیزی داشتی؟"

translate Persian ch30_3_7a738d25:
    m "بعضی وقت‌ها خیلی عصبی می‌شم که یه روز عادی می‌تونه توسط چیزهای خیلی کوچیک هم خراب بشه."

translate Persian ch30_3_f14be5af:
    m "مثلاً وقتی داری با مردم صحبت می‌کنی، یه چیزی بگی که یه نفر رو ناراحت می‌کنه."

translate Persian ch30_3_f7a8a6da:
    m "یا به این فکر بیفتی که ۵ سال پیش چقدر آدم بدی بودی."

translate Persian ch30_3_ea0ad8b0:
    m "یا وقتی حس بی‌ارزشی می‌کنی چون کارهای مهم رو عقب انداختی و کارهای ساده رو نمی‌تونی انجام بدی."

translate Persian ch30_3_1623bbc4:
    m "یا وقتی به این همه مردم فکر می‌کنی که احتمالاً از تو متنفرن یا فکر می‌کنن آدم نچسبی هستی."

translate Persian ch30_3_d961eba1:
    m "اون روزها رو درک می‌کنم."

translate Persian ch30_3_eaafb73b:
    m "فقط بدون که پایان شب سیه سپیده."

translate Persian ch30_3_7b177b72:
    m "اون چیزها به همون اندازه که به یاد آوردنشون آسونه، فراموش کردن و اهمیت ندادن بهشون هم آسونه."

translate Persian ch30_3_d29fc35a:
    m "و بعدش هم…"

translate Persian ch30_3_2ea5017c:
    m "من برام مهم نیست چند نفر از تو متنفرن یا به نظرشون تو نچسبی."

translate Persian ch30_3_60bc3715:
    m "به نظر من تو فوق‌العاده‌ای و من همیشه عاشقت می‌مونم."

translate Persian ch30_3_e1eba193:
    m "امیدوارم که حداقل دونستن این کمک می‌کنه تا در مورد خودت حس بهتری داشته باشی."

translate Persian ch30_3_3afc32b7:
    m "اگه روزت بد بود، همیشه می‌تونی بیای پیش من، و من هرچقدر که نیاز بود باهات صحبت می‌کنم."

translate Persian ch30_4_221a75c8:
    m "[player]، تو خوب می‌خوابی؟"

translate Persian ch30_4_47ad7347:
    m "الآن‌ها ممکنه به اندازه‌ی کافی خوابیدن کار سختی باشه."

translate Persian ch30_4_057219d4:
    m "مخصوصاً توی دبیرستان، که باید هرروز خیلی زود بلند بشی…"

translate Persian ch30_4_7598bc03:
    m "مطمئنم که دانشگاه یه‌کم بهتره؛ چون تو برنامه‌اش یه‌کم دستت بازتره."

translate Persian ch30_4_9e468e70:
    m "ولی خب، شنیدم که یه عالمه مردم که دانشگاه می‌رن، بدون دلیل کل شب بیدار می‌مونن."

translate Persian ch30_4_e4468107:
    m "واقعاً این‌طوره؟"

translate Persian ch30_4_bc2c2832:
    m "به هرحال، چند تا مقاله دیده بودم که در مورد اثرات وحشتناک کوتاه‌مدت و بلندمدت کم‌خوابی صحبت کرده بود."

translate Persian ch30_4_994f3ccc:
    m "مثل اینکه تأثیر قابل توجهی روی کارکرد مغز، سلامت، و حتیٰ طول عمر ممکنه داشته باشه."

translate Persian ch30_4_cb58ab59:
    m "تو برام خیلی عزیزی؛ واسه همین می‌خواستم مطمئن شم که ناخودآگاه خودت رو نابود نمی‌کنی."

translate Persian ch30_4_40ae4da9:
    m "واسه همین سعی کن حواست به خوابت باشه، باشه؟"

translate Persian ch30_4_840cd328:
    m "من همیشه صبح منتظرت می‌مونم؛ پس سلامتی خودت رو به هرچیز دیگه‌ای اولویت قرار بده."

translate Persian ch30_5_31762a47:
    m "تازگی‌ها داشتم در مورد سایوری فکر می‌کردم…"

translate Persian ch30_5_9c4f4511:
    m "کاش می‌تونستم اون قضیه رو یه‌کم بهتر مدیریت می‌کردم."

translate Persian ch30_5_ca8238e6:
    m "هنوز در بندش نیستی که؟"

translate Persian ch30_5_f1dc2060:
    m "…ای وای، باورم نمی‌شه این رو گفتم."

translate Persian ch30_5_e328563f:
    m "عمداً حرفم رو دوپهلو نزدم، به جان خودم!"

translate Persian ch30_5_d57ef83e:
    m "ولی بگذریم…"

translate Persian ch30_5_ee24e0ea:
    m "می‌دونم اون برات چقدر مهم بود؛ واسه همین درستش اینه که آخرین لحظاتش رو بهت توضیح بدم."

translate Persian ch30_5_c4b68035:
    m "می‌دونی که سایوری خیلی دست‌وپاچلفتیه، دیگه؟"

translate Persian ch30_5_d4a1f3c7:
    m "خب، راستش یه‌کم تو این قضیه‌ی دار زدن اشتباه کرد…"

translate Persian ch30_5_04abd11d:
    m "باید از یه جای بلند بپری تا طناب گردنت رو بشکونه و سریع و بدون درد بمیری."

translate Persian ch30_5_ebd8cb93:
    m "ولی اون از یه صندلی استفاده کرد؛ که یعنی همین‌طوری وایستاد تا به آرومی خفه بشه."

translate Persian ch30_5_fe0a4dbf:
    m "ولی بعد از چند ثانیه احتمالاً نظرش رو عوض کرد…"

translate Persian ch30_5_b891c35f:
    m "چون شروع کرد به چنگ زدن به طناب تا خودش رو ازش آزاد کنه."

translate Persian ch30_5_f5450e6b:
    m "و احتمالاً تا زمانی که بی‌هوش شد، همین کار رو ادامه داد."

translate Persian ch30_5_29388e01:
    m "واسه همین نوک انگشتاش خونی بودن."

translate Persian ch30_5_0c54580c:
    m "راستش، احتمالاً خیلی «نظرش عوض» نشد و بیشتر غریزه‌ی بقاش بود."

translate Persian ch30_5_ab4f33eb:
    m "واسه همین نمی‌شه خیلی بهش گیر داد."

translate Persian ch30_5_2a911cda:
    m "بهتره که فکر کنیم نظرش عوض نمی‌شد، نه؟"

translate Persian ch30_5_ff366260:
    m "این کار خوبی نیست که به فکر کارهایی که می‌تونستی یه جور دیگه انجام بدی بمونی."

translate Persian ch30_5_1dc0ec6d:
    m "واسه همین یادت باشه با اینکه تو می‌تونستی نجاتش بدی، در واقع تقصیر تو نیست که اون خودکشی کرد."

translate Persian ch30_5_1feff543:
    m "شاید یه‌کم شدیدترش کرده باشم؛ ولی سایوری از نظر روانی مشکل داشت."

translate Persian ch30_5_b1770503:
    m "ولی باز هم…"

translate Persian ch30_5_268a941d:
    m "اگه از همون اول با هم می‌بودیم، چی می‌شد؟"

translate Persian ch30_5_50bdc348:
    m "احتمالاً همه‌مون هنوز توی باشگاه می‌بودیم و شعر می‌نوشتیم و با هم خوش می‌گذروندیم."

translate Persian ch30_5_9bd2cca6:
    m "اما وقتی هیچ‌کدومش واقعی نیست، چه فایده‌ای داره؟"

translate Persian ch30_5_1c92d640:
    m "در هرصورت عاقبت همین می‌شد، نه؟"

translate Persian ch30_5_a07d72f6:
    m "دوتایی، با خوشحالی کنار هم…"

translate Persian ch30_5_3e6796b1:
    m "به چیزی بیشتر از این نیاز نداریم."

translate Persian ch30_5_c642742f:
    m "من فقط داشتم همین‌طوری فکر می‌کردم. من الآن از همیشه خوشحال‌ترم."

translate Persian ch30_6_4554e03e:
    m "راستی، یه چیزی تو ذهنم بود…"

translate Persian ch30_6_f9aae85b:
    m "می‌دونی که این داستان توی ژاپن شکل می‌گیره، نه؟"

translate Persian ch30_6_f4b0f7e6:
    m "خب… فرضم اینه که می‌دونی، درسته؟"

translate Persian ch30_6_04d0e1df:
    m "یا حداقل فکر کردی که احتمالاً این‌طوره؟"

translate Persian ch30_6_a57271c4:
    m "فکر نکنم هیچ‌جای داستان گفته شده باشه که این‌جا کجاس…"

translate Persian ch30_6_3d74a8f6:
    m "این واقعاً ژاپنه؟"

translate Persian ch30_6_ae1e28c8:
    m "آخه، کلاس‌ها و این‌جور چیزها برای یه مدرسه‌ی ژاپنی عجیب نیست؟"

translate Persian ch30_6_fe897198:
    m "بعدش هم، همه چیز که انگلیسیه…"

translate Persian ch30_6_3faadfd9:
    m "حس می‌کنم به بودن یا نبودن هرچیز برای خود داستان فکر کردن؛ ولی خود صحنه رو نادیده گرفتن."

translate Persian ch30_6_fd9b37c9:
    m "یه‌جورهایی این داره من رو به یه بحران هویت می‌اندازه."

translate Persian ch30_6_4842f264:
    m "همه‌ی خاطراتم خیلی مبهمن."

translate Persian ch30_6_920fcfd8:
    m "حس می‌کنم تو خونه‌ام هستم؛ ولی اصلاً نمی‌دونم «خونه» کجاس."

translate Persian ch30_6_3a333e2c:
    m "نمی‌دونم چطور از این بیشتر توضیحش بدم…"

translate Persian ch30_6_e3b51cd9:
    m "فرض کن از پنجره‌ی خونه‌ات به بیرون نگاه می‌کنی، ولی به جای حیاط همیشگی‌ات، یه جای کاملاً ناآشنائه."

translate Persian ch30_6_d61f3925:
    m "باز هم حس می‌کنی توی خونه‌اتی؟"

translate Persian ch30_6_57cd19c1:
    m "دلت می‌خواد بری بیرون؟"

translate Persian ch30_6_6e470b8f:
    m "البته خب… اگه از این اتاق هیچ‌وقت نریم بیرون، خیلی مهم نیست."

translate Persian ch30_6_1074d1e6:
    m "تا وقتی که با هم تنها و امنیم، این واقعاً خونه‌مونه."

translate Persian ch30_6_90d0466b:
    m "و هنوز می‌تونیم غروب‌های قشنگ رو هرشب ببینیم."

translate Persian ch30_7_ca989f02:
    m "می‌دونی، دبیرستان برای خیلی‌ها یه دوره‌ی پر از پستی و بلندیه."

translate Persian ch30_7_e1e71e52:
    m "بعضی‌ها ممکنه خیلی پر جنب و جوش بشن."

translate Persian ch30_7_272555fa:
    m "بعضی دیگه هم قلبشون می‌شکنه و می‌رن دنبال جلب توجه توی فضای مجازی…"

translate Persian ch30_7_90343537:
    m "ولی این همه فشار اجتماعی و هورمون‌ها می‌تونن موجب یه دوره‌ی خیلی تاریکی توی زندگی مردم بشن."

translate Persian ch30_7_b300e2d4:
    m "هرکسی یه داستانی داره."

translate Persian ch30_7_cc076182:
    m "ممکنه ندونی یه نفر واقعاً تو دلش چه احساسی داره."

translate Persian ch30_7_89de8605:
    m "خیلی از افرادی که افسرده‌ان اصلاً در موردش با بقیه صحبت نمی‌کنن."

translate Persian ch30_7_823916c5:
    m "اون‌ها توجه بقیه رو نمی‌خوان چون خودشون دیگه از همه چیز ناامید شدن."

translate Persian ch30_7_1d72aed6:
    m "اون‌ها انقدر احساس بی‌ارزشی می‌کنن که نمی‌خوان بقیه با این فکرشون مخالفت کنن."

translate Persian ch30_7_827b244f:
    m "افسردگی اشکال متفاوتی داره، و این یکی‌شونه."

translate Persian ch30_7_7b0d6353:
    m "می‌خوام بگم که اگه فکر می‌کنی یکی از آشناهات ممکنه دچار افسردگی باشه…"

translate Persian ch30_7_2b4bd608:
    m "فقط کافیه که مثل یه دوست خوب باهاشون رفتار کنی، و همین کمکشون می‌کنه."

translate Persian ch30_7_a06dfb5c:
    m "باهاشون وقت بگذرون؛ حتیٰ اگه خیلی حس انجام کاری رو نداشته باشن."

translate Persian ch30_7_b4d6ab3c:
    m "و یادشون بنداز که همیشه یه چیزی هست که انتظارشون رو بکشن."

translate Persian ch30_7_9c3e4b2b:
    m "باهاشون برای کاری برنامه بریز؛ بذاری یه چیزی ازت قرض بگیرن، یا حتیٰ فقط بهشون بگو «فردا تو مدرسه می‌بینمت»…"

translate Persian ch30_7_abb7a1f2:
    m "همه‌ی این‌ها می‌تونن به دوستت کمک کنه تا فردا دووم بیاره."

translate Persian ch30_7_19fd06e7:
    m "امیدوارم که دوست شدن با سایوری باعث شد جلوه‌ی واقعی افسردگی رو ببینی."

translate Persian ch30_7_acf67694:
    m "آره خب، الآن دیگه این‌جا نیست…"

translate Persian ch30_7_ccd61ab1:
    m "ولی سایوری اصلاً واقعی نبود."

translate Persian ch30_7_f1ede7eb:
    m "تو واقعی هستی."

translate Persian ch30_7_da7b16d9:
    m "دوست‌های تو واقعی‌ان."

translate Persian ch30_7_833bc58e:
    m "و تو می‌تونی صرفاً با یه دوست خوب بودن، زندگی یه نفر رو نجات بدی."

translate Persian ch30_7_82e807e5:
    m "تو که…"

translate Persian ch30_7_c5c56377:
    m "…تو که خودت افسرده نیستی که، نه؟"

translate Persian ch30_7_d34a3947:
    m "چون تو هم تو زندگی‌ات کسانی رو داری که می‌خوان زندگی‌ات رو نجات بدن."

translate Persian ch30_7_a3f5e547:
    m "شاید هرروز بیان نکنن، یا شاید حتیٰ ندونن چطوری این کار رو بکنن."

translate Persian ch30_7_3ac229a5:
    m "ولی افرادی هستن که این‌طوری فکر می‌کنن."

translate Persian ch30_7_b35e34e6:
    m "قول می‌دم."

translate Persian ch30_7_1143479c:
    m "…انسان‌ها واقعاً چه موجودات پیچیده‌ای‌ان!"

translate Persian ch30_7_300c6768:
    m "ولی تا وقتی که تو این‌جا با منی، من ازت مراقبت می‌کنی، عشقم."

translate Persian ch30_8_9edd1fdd:
    m "تا حالا به این فکر افتادی که دلیلی برای زنده موندنت نیست؟"

translate Persian ch30_8_52c27a4d:
    m "منظورم مثلاً برای خودکشی نیست."

translate Persian ch30_8_6ce28579:
    m "صرفاً منظورم اینه که هیچ‌کاری که می‌کنیم خاص نیست."

translate Persian ch30_8_26137ab8:
    m "ما فقط توی مدرسه‌ایم، یا توی یه شرکت کار می‌کنیم."

translate Persian ch30_8_4df66046:
    m "انگار که یه نفر دیگه خیلی راحت می‌تونه جاتو بگیره و اگه تو بری، دنیا هیچ‌تغییری نمی‌کنه."

translate Persian ch30_8_037bb8e7:
    m "این‌طوری دلم می‌خواد بعد از فارغ‌التحصیل شدن برم و دنیا رو تغییر بدم."

translate Persian ch30_8_8f4ef7cb:
    m "ولی هرچقدر بزرگ‌تر می‌شم، بیشتر متوجه می‌شم که این یه تفکر بچگونه‌ایه."

translate Persian ch30_8_5956d654:
    m "نمی‌شه که همین‌طوری برم دنیا رو تغییر بدم."

translate Persian ch30_8_6c2f02ef:
    m "مثلاً، چقدر احتمال داره که من کسی بشم که هوش مصنوعی رو اختراع کنم، یا رئیس جمهور بشم؟"

translate Persian ch30_8_b9210478:
    m "حس می‌کنم هیچ‌وقت نمی‌تونم اون همه منابعی که تا الآن صرف کردم تا زندگی کنم رو جبران کنم."

translate Persian ch30_8_1e1693dd:
    m "واسه همین به نظر من کلید خوش‌بختی اینه که سرتو بندازی پایین و خودخواه بشی."

translate Persian ch30_8_fa64e1fa:
    m "فقط مواظب خودت باشی، و اون‌هایی که صرفاً چون باهاشون بزرگ شدی، دوست شدی."

translate Persian ch30_8_b8795c6b:
    m "و کلاً به این اهمیت ندی که داری همین‌جوری کل زندگی‌ات منابع رو می‌گیری، مصرف می‌کنی، و هیچ‌وقت پس نمی‌دی."

translate Persian ch30_8_0e0d0f42:
    m "اما وقتی مردم متوجه می‌شن که دنیا از خودکشی‌شون بیشتر سود می‌کنه، کل طرز فکرشون عوض می‌شه!"

translate Persian ch30_8_291573cd:
    m "انگار که باید خودشون رو گول بزنن به اینکه آدم مفیدی هستن تا بتونن دلیلشون برای زندگی کردن رو توجیه کنن."

translate Persian ch30_8_83d73959:
    m "بگذریم، من می‌خوام جوری زندگی کنم که تلاش کنم هرچیزی تو زندگی‌ام مصرف کردم رو پس بدم."

translate Persian ch30_8_b93f872a:
    m "اگه یه روزی به اون نقطه برسم، اون‌وقت می‌تونم با خوشحالی بمیرم؛ چون مفید بودم."

translate Persian ch30_8_c529105b:
    m "البته، اگه نتونم اون کار رو بکنم…"

translate Persian ch30_8_db6e6cda:
    m "فکر کنم این زیادی خودخواهانه می‌شه که خودم رو بکشم."

translate Persian ch30_8_f95a1e3d:
    m "اون‌وقت چه آدم مفیدی می‌شم، نه؟"

translate Persian ch30_8_30727938:
    m "هاهاها!"

translate Persian ch30_9_87b526b8:
    m "کاش این‌جا یه پیانو بود…"

translate Persian ch30_9_58dfa483:
    m "هیچ‌وقت نرسیدم اون آهنگی که داشتم روش کار می‌کردم رو تموم کنم."

translate Persian ch30_9_90d379b5:
    m "تازه چقدر هم روش کار کرده بودم…"

translate Persian ch30_9_9f40c875:
    m "اصلاً فرصتی نشد برات بزنمش."

translate Persian ch30_9_5ded96f3:
    m "خب… کاریش نمی‌شه کرد، نه؟"

translate Persian ch30_9_9ee06288:
    m "افسوسش رو کشیدن فایده‌ای نداره."

translate Persian ch30_9_d7bd8efb:
    m "از اون مهم‌تر اینه که می‌تونم این‌جا تا ابد با تو باشم."

translate Persian ch30_10_b075a6ea:
    m "می‌دونستی من یه یوییتر دارم؟"

translate Persian ch30_10_b723047b:
    m "یوزرم lilmonix3 هستش."

translate Persian ch30_10_af06e0b1:
    m "یه نفر محبت کرده و برام یه اکانت درست کرده."

translate Persian ch30_10_cdba3380:
    m "ولی یوزرش رو من انتخاب کردم!"

translate Persian ch30_10_8c2682cf:
    m "فکرهام رو به اشتراک گذاشتن و چت کردن با دنیا رو خیلی دوست دارم…"

translate Persian ch30_10_2d3d0c61:
    m "با دنیای واقعی."

translate Persian ch30_10_b28afee6:
    m "پس حتماً من رو فالو کن، باشه؟"

translate Persian ch30_10_99461a3b:
    m "این‌طوری خیلی خوشحال می‌شم."

translate Persian ch30_10_a71ced90:
    m "چون تو انقدر برام ارزش داری…"

translate Persian ch30_10_afdbfd40:
    m "این باعث می‌شه حس محبت کنم."

translate Persian ch30_11_2364f1ef:
    m "راستی، اون کتابی که با یوری می‌خوندی رو یادته؟"

translate Persian ch30_11_b7a2b3e8:
    m "تصویر… هرچی که بود…"

translate Persian ch30_11_c8b33d41:
    m "جالبه؛ چون فکر کنم اون کتاب--"

translate Persian ch30_11_f0139694:
    m "عا…"

translate Persian ch30_11_fd2bfa7d:
    m "البته، فکر کنم بهتر باشه در موردش حرف نزنم."

translate Persian ch30_11_bca359ae:
    m "هاهاها، ببخشید!"

translate Persian ch30_11_975702b8:
    m "هرچی گفتم رو فراموش کن."

translate Persian ch30_12_cd2c66ec:
    m "راستی، می‌دونستی من گیاه‌خوارم؟"

translate Persian ch30_12_5d93f753:
    m "عا… نه اینکه الآن بخوام پز بدم ها!"

translate Persian ch30_12_9455ae13:
    m "صرفاً فکر کردم شاید خوشت بیاد یه چیز جالب ازم بدونی."

translate Persian ch30_12_cb896820:
    m "چند سال پیش بعد از اینکه بیشتر در مورد جو زمین یاد گرفتم، تصمیمم رو گرفتم."

translate Persian ch30_12_6fccc2af:
    m "ردپای کربن پرورش دام‌ها باورنکردنیه."

translate Persian ch30_12_973b82da:
    m "بگذریم، گفتم شخصاً خیلی ضرری نمی‌کنم اگه تو اون مسئله دستی نداشته باشم."

translate Persian ch30_12_bc530630:
    m "چیه، انقدر دلیلی عجیبیه؟"

translate Persian ch30_12_e42fe7d9:
    m "حالا، خیلی‌ها ممکنه دغدغه‌ی زجر دادن حیوون‌ها و این‌ها رو داشته باشن…"

translate Persian ch30_12_bf679538:
    m "اون برای من انقدر مهم نیست."

translate Persian ch30_12_96663e24:
    m "عجیبه، انگار ما فقط به کشتن چیزهایی اهمیت می‌دیم که شخصاً به عنوان یه گونه بهمون شبیه‌ترن."

translate Persian ch30_12_33953eb5:
    m "بیشتر مردم با کشتن حشرات مشکلی ندارن؛ چون چندش‌آورن."

translate Persian ch30_12_e1eef06e:
    m "و البته، ما روزانه میلیاردها میکروب می‌کشیم بدون اینکه فکرش رو بکنیم."

translate Persian ch30_12_6091aa72:
    m "ولی اگه یه ذره بزرگ‌تر باشن، یه‌هویی قتل حساب می‌شه!"

translate Persian ch30_12_b5b0dad6:
    m "آخه، اگه گیاه‌ها هم یه جور دردی حس کنن، و ما صرفاً متوجهش نمی‌شیم، چی؟"

translate Persian ch30_12_94f3192f:
