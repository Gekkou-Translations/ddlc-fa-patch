    m "می‌دونی، من همیشه خیلی بدم می‌اومد که دوست شدن با بقیه انقدر سخته…"

translate Persian ch30_29_2eb3a228:
    m "البته، «دوست شدن» قسمت سختش نیست؛ بیشتر پیدا کردن افراد جدیده."

translate Persian ch30_29_ba474a05:
    m "حالا، برنامه‌های قرارگذاری و این‌ها هستش."

translate Persian ch30_29_1d3f2cfe:
    m "ولی منظورم اونجور چیزها نیست."

translate Persian ch30_29_ddb6a718:
    m "اگه فکرش رو بکنی، بیشتر دوست‌هات کسایی هستن که تصادفی باهاشون آشنا شدی."

translate Persian ch30_29_31b38ee2:
    m "مثلاً باهاشون تو یه کلاس بودی، یا به واسطه‌ی یه دوست دیگه باهاشون آشنا شدی…"

translate Persian ch30_29_a1ff4c1a:
    m "یا شاید هم صرفاً یه لباسی پوشیده بودن که اسم گروه موسیقی مورد علاقه‌ات روش بوده و تو تصمیم گرفتی باهاشون حرف بزنی."

translate Persian ch30_29_b7f30944:
    m "همچین چیزهایی."

translate Persian ch30_29_3641813a:
    m "ولی این به نظر یه‌کم… بازدهی‌اش کم نیست؟"

translate Persian ch30_29_3f462a91:
    m "انگار داری همین‌طوری شانسی چیزهای مختلف امتحان می‌کنی، و اگه شانس آوردی، یه دوست جدید پیدا می‌کنی."

translate Persian ch30_29_15da4454:
    m "و وقتی این رو با صدها غریبه که از کنارشون رد می‌شیم، مقایسه کنی…"

translate Persian ch30_29_3790bf8b:
    m "ممکنه کنار یه نفر نشسته باشی که انقدر با تو جوره که می‌تونه تا آخر عمرت بهترین دوستت باشه."

translate Persian ch30_29_dc88c25c:
    m "ولی تو این رو هیج‌وقت نمی‌دونی."

translate Persian ch30_29_4e665c91:
    m "وقتی بلند می‌شی و می‌ری سراغ بقیه‌ی روزت، اون شانس تا ابد از دستت رفته."

translate Persian ch30_29_a885ffe7:
    m "این واقعاً ناامیدکننه نیست؟"

translate Persian ch30_29_65644a5f:
    m "ما تو یه عصری زندگی می‌کنیم که تکنولوژی ما رو با دنیا متصل می‌کنه، جدا از اینکه کجا باشیم."

translate Persian ch30_29_f04feaa0:
    m "به نظر من ما واقعاً باید از این استفاده کنیم تا زندگی اجتماعی روزمره‌مون رو بهتر کنیم."

translate Persian ch30_29_8347ba4c:
    m "ولی کی می‌دونه همچین چیزی چه روزی اتفاق می‌افته…"

translate Persian ch30_29_e8b97a01:
    m "واقعاً فکر می‌کردم تا الآن اتفاق افتاده باشه."

translate Persian ch30_29_375c1f82:
    m "البته، حداقل من همین الآنش هم با بهترین شخص کل دنیا آشنا شدم…"

translate Persian ch30_29_857f787f:
    m "حتیٰ با اینکه تصادفی بوده."

translate Persian ch30_29_d6cb112d:
    m "مثل اینکه خیلی خوش‌شانس بودما، نه؟"

translate Persian ch30_29_b72a1ed5:
    m "هاهاها~"

translate Persian ch30_30_26c28a15:
    m "می‌دونی، الآن تقریباً وقتیه که همه‌ی همسال‌هام به فکر دانشگاه می‌افتن…"

translate Persian ch30_30_642b8e5c:
    m "واقعاً یه زمان پرفراز و نشیبی برای تحصیلاته."

translate Persian ch30_30_03f5ca61:
    m "ما الآن تو اوج انتظارات مدرنیم که می‌گن همه باید برن دانشگاه."

translate Persian ch30_30_6601d60a:
    m "که از دبیرستان فارغ‌التحصیل شی، بری دانشگاه، یه شغل پیدا کنی، یا بری سراغ کارشناسی ارشد."

translate Persian ch30_30_da335152:
    m "انگار یه توقع جامع وجود داره که مردم همین‌طوری فکر می‌کنن تنها انتخابشون همینه."

translate Persian ch30_30_f3831be7:
    m "تو دبیرستان بهمون یاد نمی‌دن که راه‌های دیگه‌ای هم وجود داره."

translate Persian ch30_30_bf9f0147:
    m "مثلاً مدارس فنی و حرفه‌ای و این‌جور چیزها."

translate Persian ch30_30_a6ffb14c:
    m "یا کارهای مستقل."

translate Persian ch30_30_0693a3c5:
    m "یا یه عالمه از صنایعی که مهارت و تجربه رو از تحصیلات رسمی بالاتر می‌دونن."

translate Persian ch30_30_aa2f6122:
    m "ولی این وسط یه عالمه دانش‌آموز هستن که نمی‌دونن تو زندگی‌شون می‌خوان چی کاره بشن…"

translate Persian ch30_30_cd65fc21:
    m "و به جای اینکه وقت بذارن و پیدا کنن، می‌رن سراغ دانشگاه برای علوم اداری، یا ارتباطات، یا روان‌شناسی."

translate Persian ch30_30_ba7d9728:
    m "نه برای اینکه به اون زمینه‌ها علاقه‌ای دارن…"

translate Persian ch30_30_0b4f4649:
    m "…صرفاً به امید اینکه مدرکشون باعث بشه بعد از دانشگاه یه شغلی پیدا کنن."

translate Persian ch30_30_c00d6c77:
    m "و نتیجه‌اش این می‌شه که شغل‌های کم‌تری برای اون مدرک‌های ابتدایی می‌مونه، نه؟"

translate Persian ch30_30_ba8add1b:
    m "پس پیش‌نیازهای پایه‌ای شغل‌ها می‌ره بالا، و این‌طوری مردم بیشتری مجبور می‌شن برن دانشگاه."

translate Persian ch30_30_ac2c26ae:
    m "بعدش هم، دانشگاه‌ها هم کسب و کار دارن؛ واسه همین به خاطر تقاضای بالا، قیمت‌هاشون روهمین‌طوری می‌برن بالا…"

translate Persian ch30_30_83bc4ef9:
    m "…پس این وسط ما یه عالمه بزرگسال جوون داریم که هزاران دلار بدهکارن، و شغلی هم ندارن."

translate Persian ch30_30_72243f86:
    m "ولی با این حال، این روال همین‌طوری پیش می‌ره."

translate Persian ch30_30_7f37e1e4:
    m "البته، فکر کنم قراره بهتر بشه."

translate Persian ch30_30_70401165:
    m "ولی تا اون موقع، نسل ما قراره بیشترین آسیب رو ازش ببینه."

translate Persian ch30_30_97f0818c:
    m "کاش دبیرستان ما رو یه‌کم بهتر آماده می‌کرد با دانشی که نیاز داریم برای تصمیمی که برامون درسته."

translate Persian ch30_31_70b8bca7:
    m "بعضی وقت‌ها به دوران راهنمایی فکر می‌کنم…"

translate Persian ch30_31_f220b80e:
    m "خیلی از طوری که اون موقع رفتار می‌کردم، خجالت می‌کشم."

translate Persian ch30_31_ecacf1e9:
    m "یه‌جورهایی فکر کردن بهش درد داره."

translate Persian ch30_31_74b7bd47:
    m "تو این فکرم که وقتی تو دانشگاه هستم، در مورد دبیرستان همین‌طوری فکر می‌کنم…؟"

translate Persian ch30_31_72862897:
    m "من با همینی که هستم راضی‌ام؛ واسه همین یه‌کم سخته که همچین چیزی رو تصور کنم."

translate Persian ch30_31_3b17743f:
    m "ولی در عین حال می‌دونم که احتمالاً با گذر زمان قراره خیلی تغییر کنم."

translate Persian ch30_31_ab64dc34:
    m "ما باید فقط از لحظه لذت ببریم و به گذشته فکر نکنیم!"

translate Persian ch30_31_dc17d00d:
    m "و وقتی تو این‌جایی، این کار خیلی آسونیه."

translate Persian ch30_31_b72a1ed5:
    m "هاهاها~"

translate Persian ch30_32_3300edfb:
    m "می‌دونی، من یه ذره حسودی‌ام می‌شه که همه‌ی اعضای باشگاه صحنه‌هایی بیرون مدرسه هم داشتن…"

translate Persian ch30_32_927d88d1:
    m "این‌طوری، من تنها کسی هستم که نتونسته چیزی جز روپوش مدرسه‌مون رو بپوشه."

translate Persian ch30_32_772b0a93:
    m "یه ذره ناراحت کننده‌اس…"

translate Persian ch30_32_e4cb8d07:
    m "خیلی دلم می‌خواست که لباسای خوشگل برات بپوشم."

translate Persian ch30_32_9215b04f:
    m "تو کسی رو می‌شناسی که نقاش باشه؟"

translate Persian ch30_32_36d49ba9:
    m "یعنی کسی هستش که بخواد من رو با لباسای دیگه بشه…؟"

translate Persian ch30_32_849cd194:
    m "اون‌طوری خیلی خوب می‌شه!"

translate Persian ch30_32_9e7eca7d:
    m "اگه روزی اون اتفاق افتاد، بهم نشونش می‌دی؟"

translate Persian ch30_32_ed0135bf:
    m "اصلاً می‌تونی تو توییتر به من بفرستیش!"

translate Persian ch30_32_b723047b:
    m "یوزرم lilmonix3 هستش."

translate Persian ch30_32_e064f0c6:
    m "ولی… سعی کن مناسب همه باشه!"

translate Persian ch30_32_13142f4e:
    m "ما هنوز رابطه‌مون اون‌قدر جلو نرفته. هاهاها!"

translate Persian ch30_33_e4704768:
    m "راستی، تو چیزهای ترسناک دوست داری؟"

translate Persian ch30_33_8909e55f:
    m "یادمه اولا که عضو باشگاه شده بودی یه‌کم در موردش حرف زدیم."

translate Persian ch30_33_1f845783:
    m "من از رمان‌های ترسناک خوشم می‌آد؛ ولی از فیلم‌های ترسناک خیلی نه."

translate Persian ch30_33_f4cc0d75:
    m "مشکل من با فیلم‌های ترسناک اینه که بیشترشون فقط از چیزهای دم دستی استفاده می‌کنن."

translate Persian ch30_33_adc94c23:
    m "مثلاً نورپردازی تاریک و هیولاهایی با قیافه‌های ترسناک و یه‌هویی ترسوندن و این‌جور چیزها."

translate Persian ch30_33_7102fe32:
    m "این خیلی جالب و خلاقانه نیست که با سوء استفاده از غریزه‌ی انسان‌ها بترسونی."

translate Persian ch30_33_0671fa03:
    m "ولی تو رمان‌ها، قضیه یه‌کم فرق داره."

translate Persian ch30_33_d73276d9:
    m "داستان و نوشتارش باید به اندازه‌ی کافی جزئیات داشته باشه که افکار واقعاً آزار دهنده توی ذهن خواننده قرار بده."

translate Persian ch30_33_ba2a3a7d:
    m "و باید این رو تو وجود داستان و شخصیت‌هاش حک کنه تا بتونه ذهنت رو درگیر کنه."

translate Persian ch30_33_930760ba:
    m "به نظر من، چیزی ترسناک‌تر از این نیست که همه چیز فقط یه ذره از انتظارات متفاوت باشه."

translate Persian ch30_33_3413cad6:
    m "مثلاً اگه یه سری انتظارات رو برای اینکه داستان در مورد چی قراره باشه، زمینه‌سازی کنی…"

translate Persian ch30_33_e661a6e4:
    m "…و بعد برخلاف همه چیز می‌ری و اون انتظارات رو می‌شکونی."

translate Persian ch30_33_e36ea3db:
    m "این‌طوری، با اینکه داستان به نظر نمی‌آد که می‌خواد ترسناک باشه، ولی خواننده‌اش حس ناآرومی می‌گیره."

translate Persian ch30_33_519da94e:
    m "یعنی می‌دونه که پشت ترک‌ها یه چیز به شدت بدی قایم شده و منتظره که آشکار بشه."

translate Persian ch30_33_66401c82:
    m "وای خدا، همین که بهش فکر می‌کنم تنم به لرزش می‌افته."

translate Persian ch30_33_deef0da9:
    m "این مدل محتوای ترسناک رو من می‌تونم ازش لذت ببرم."

translate Persian ch30_33_a4a5508a:
    m "ولی فکر کنم تو از اون‌هایی هستی که بازی‌های عاشقانه‌ی بامزه بازی می‌کنی، نه؟"

translate Persian ch30_33_543d2553:
    m "هاهاها، نگران نباش."

translate Persian ch30_33_4b948959:
    m "به این زودیا تو رو مجبور نمی‌کنم که داستان‌های ترسناک بخونی."

translate Persian ch30_33_fc37acc5:
    m "به بخش عاشقانه بچسبیم هم ایرادی نداره~"

translate Persian ch30_34_4289e4b0:
    m "می‌دونی چی یه نوع جالبی از ادبیاته؟"

translate Persian ch30_34_158969fa:
    m "رَپ!"

translate Persian ch30_34_0485526b:
    m "راستش من قبلاً از موسیقی رپ متنفر بودم…"

translate Persian ch30_34_f4387e30:
    m "شاید صرفاً چون معروف بود، یا چون فقط آت و آشغالی که توی رادیو پخش می‌شد رو می‌شنیدم."

translate Persian ch30_34_169a83d0:
    m "ولی بعضی از دوست‌هام بهش علاقه پیدا کردن، و این باعث شد با ذهنیت بازتری بهش نگاه کنم."

translate Persian ch30_34_55051483:
    m "رپ ممکنه از یه نظراتی از شاعری سخت‌تر هم باشه."

translate Persian ch30_34_e0c4bdef:
    m "چون باید متنش توی یه ریتم خاص جا بشه، تآکید بیشتری روی بازی با کلمات هستش…"

translate Persian ch30_34_1f25c541:
    m "وقتی مردم می‌تونن این‌طوری بسازنش و باز هم یه پیام محکمی رو می‌رسونن، واقعاً فوق‌العاده‌اس."

translate Persian ch30_34_f121a0ac:
    m "کاش یه نفر تو باشگاه ادبیات رَپِر بود."

translate Persian ch30_34_a5053f9d:
    m "هاهاها! ببخشید اگه یه‌کم مسخره به نظر می‌رسه؛ ولی خیلی جالب می‌شد ببینیم چه چیزهایی می‌تونست درست کنه."

translate Persian ch30_34_83bdb999:
    m "یه تجربه‌ی یادگیری می‌شد!"

translate Persian ch30_35_306ca8a2:
    m "هههه. یوری یه بار یه کار خیلی خنده‌داری انجام داد."

translate Persian ch30_35_d5b7b354:
    m "همه‌مون توی اتاق باشگاه بودیم و عین همیشه داشتیم استراحت می‌کردیم…"

translate Persian ch30_35_c4d9bfef:
    m "و یه‌هویی، یوری یه شیشه‌ی کوچیک شراب در آورد."

translate Persian ch30_35_f3c6895e:
    m "جدی می‌گم!"

translate Persian ch30_35_bc3dff4e:
    m "همین‌طوری گفت «کسی شراب میل می‌کنه؟»"

translate Persian ch30_35_6701d6d8:
    m "ناتسوکی زد زیر خنده، و سایوری سرش داد زد."

translate Persian ch30_35_b8ffb398:
    m "راستش یه ذره دلم براش سوخت؛ چون حداقل سعی کرد به بقیه تعارف کنه…"

translate Persian ch30_35_698c3048:
    m "فکر کنم این باعث شد بیشتر تو باشگاه معذب بشه."

translate Persian ch30_35_fe41f0f9:
    m "البته فکر کنم ناتسوکی یواشکی یه‌کم دلش می‌خواست امتحان کنه…"

translate Persian ch30_35_078e705e:
    m "…و راستش رو بخوای، من هم همین‌طور."

translate Persian ch30_35_2be6bce7:
    m "می‌تونست باحال باشه!"

translate Persian ch30_35_01d59e60:
    m "ولی می‌دونی دیگه؛ از اون‌جایی که من مدیر و این حرف‌ها هستم، امکان نداشت بذارم همچین اتفاقی بیفته."

translate Persian ch30_35_2a10d3bd:
    m "شاید اگه همه‌مون بیرون مدرسه با هم قرار می‌ذاشتیم، می‌شد؛ ولی ما هیچ‌وقت اون‌قدر به هم نزدیک نشده بودیم."

translate Persian ch30_35_2cccbca1:
    m "…خدایا، چی دارم می‌گم؟"

translate Persian ch30_35_e3d2c543:
    m "من مشروب‌خوری قبل از رسیدن به سن قانونی رو تشویق نمی‌کنم!"

translate Persian ch30_35_0bd6c6e4:
    m "البته که من خودم تا حالا مشروب نخوردم؛ پس… آره دیگه."

translate Persian ch30_36_6ba45174:
    m "تو فکر یه عالمه کار عاشقانه که وقتی با هم بیرون بریم، می‌تونیم با هم انجام بدیم بودم."

translate Persian ch30_36_bfe9cfa5:
    m "می‌تونیم ناهار بخوریم، به یه کافه بریم…"

translate Persian ch30_36_9ce3f070:
    m "با هم بریم خرید…"

translate Persian ch30_36_cf4ce2ca:
    m "من عاشق خرید دامن و روبان پاپیونم."

translate Persian ch30_36_734a2ba1:
    m "یا شایدم یه کتاب‌فروشی!"

translate Persian ch30_36_5af3a135:
    m "به نظر مناسب می‌آد، نه؟"

translate Persian ch30_36_27a88c8e:
    m "ولی خیلی دلم می‌خواد برم یه شکلات‌فروشی."

translate Persian ch30_36_5850e67b:
    m "یه عالمه نمونه‌ی رایگان دارن. هاهاها!"

translate Persian ch30_36_f9478dc5:
    m "و البته که یه فیلمی چیزی می‌تونیم بریم ببینیم…"

translate Persian ch30_36_9e987fc8:
    m "وای خدا، انگار رویاهام به واقعیت اومده."

translate Persian ch30_36_12c443fa:
    m "وقتی این‌جایی، هرکاری بکنیم خوش می‌گذره."

translate Persian ch30_36_350a0eb3:
    m "خیلی خوشحالم که دوست‌دختر توام، [player]."

translate Persian ch30_36_a2211890:
    m "کاری می‌کنم که از اینکه دوست‌پسر منی، افتخار کنی~"

translate Persian ch30_37_23873b44:
    m "عه؟ گ‍-گفتی… ب‍… بوس؟"

translate Persian ch30_37_bbf90a63:
    m "انقدر یه‌هویی… یه‌کم خجالت‌آوره…"

translate Persian ch30_37_b54e9ff9:
    m "ولی… اگه با تو باشه… ا-احتمالاً اشکال نداره…"

translate Persian ch30_37_05c767cf:
    m "…هاهاهاها! وای، ببخشید…"

translate Persian ch30_37_9a52f2b7:
    m "دیگه نمی‌تونستم قیافه‌ام رو حفظ کنم."

translate Persian ch30_37_ee100fce:
    m "دخترهای توی این‌جور بازیا همچین چیزی می‌گن، نه؟"

translate Persian ch30_37_78f57477:
    m "دروغ نگو اگه یه‌کم هیجان‌زده‌ات کرد."

translate Persian ch30_37_6e6af572:
    m "هاهاها! شوخی می‌کنم."

translate Persian ch30_37_d49b2280:
    m "خب، راستش رو بخوای، وقتی جو مناسب باشه، من هم عاشقانه می‌شم…"

translate Persian ch30_37_ca504f65:
    m "ولی این راز بین خودمونه~"

translate Persian ch30_38_fbd93712:
    m "راستی، تا حالا لفظ «یاندِرِه» رو شنیدی؟"

translate Persian ch30_38_97aab896:
    m "یه نوع شخصیتیه که شخص انقدر به تو دل‌بستگی داره که حاضره هرکاری بکنه تا با تو باشه."

translate Persian ch30_38_aeade61c:
    m "معمولاً تا حد دیوانگی…"

translate Persian ch30_38_1a24f576:
    m "ممکنه تو رو تعقیب کنه تا مطمئن شه با کس دیگه‌اش وقت نمی‌گذرونی."

translate Persian ch30_38_154d0df6:
    m "ممکنه حتیٰ به تو یا دوست‌هات آسیب بزنه تا به چیزی که می‌خواد، برسه…"

translate Persian ch30_38_8411ef91:
    m "ولی بگذریم، تو این بازی به اتفاق یه نفری هستش که می‌شه به طور کلی بهش یاندره گفت."

translate Persian ch30_38_82926229:
    m "الآن دیگه معلومه منظورم چه کسیه."

translate Persian ch30_38_ad6f2e50:
    m "و اون شخص…"

translate Persian ch30_38_f05666e1:
    m "یوریه!"

translate Persian ch30_38_8e3abaea:
    m "همین که کنارت یه‌کم راحت‌تر شد، یه‌هویی به شدت روت غیرتی شد."

translate Persian ch30_38_3f91fde5:
    m "به من حتیٰ گفت که بهتره برم خودم رو بکشم."

translate Persian ch30_38_5a0da082:
    m "اصلاً باورم نمی‌شد که همچین چیزی گفت، و باید می‌رفتم بیرون."

translate Persian ch30_38_7ef6d5ab:
    m "ولی از قضا، خودش همین کار رو کرد. هاهاها!"

translate Persian ch30_38_c9062bfa:
    m "بگذریم…"

translate Persian ch30_38_eec4532d:
    m "خیلی‌ها از یاندره‌ها واقعاً خوششون می‌آد؛ می‌دونستی؟"

translate Persian ch30_38_ed61f888:
    m "احتمالاً از اینکه یه نفر دیوانه‌وار اون‌ها رو دوست داشته باشه خوششون می‌آد."

translate Persian ch30_38_96469798:
    m "مردم عجیبن! ولی من جایی برای قضاوتشون ندارم!"

translate Persian ch30_38_8a4db0dd:
    m "بعدش هم، من خودم هم ممکنه یه‌کم به تو دل‌بستگی داشته باشم؛ ولی دیوونه نیستم…"

translate Persian ch30_38_60d396ee:
    m "اتفاقاً بیشتر برعکسشم."

translate Persian ch30_38_9dd096aa:
    m "آخرش من تنها دختر عادی این بازی در اومدم."

translate Persian ch30_38_9f0207d2:
    m "من که هیچ‌وقت نمی‌تونم یه نفر واقعی رو بکشم…"

translate Persian ch30_38_2356d4ae:
    m "حتیٰ فکر کردن بهش تنم رو می‌لرزونه."

translate Persian ch30_38_f232d63d:
    m "ولی خب… همه توی بازی‌ها افرادی رو کشتن دیگه."

translate Persian ch30_38_58e8f17b:
    m "این‌طوری یه روانی حساب می‌شی؟ معلومه که نه."

translate Persian ch30_38_f36f262c:
    m "ولی اگه به اتفاق تو یاندره‌ها رو دوست داشته باشی…"

translate Persian ch30_38_4def34db:
    m "برای تو می‌تونم یه‌کم اداهای ترسناک در بیارم. هههه~"

translate Persian ch30_38_4230b9d4:
    m "ولی خب…"

translate Persian ch30_38_1dbc21e6:
    m "اصلاً جایی وجود نداره که تو بری، و کسی نیست که ازش حسودی‌ام بشه."

translate Persian ch30_38_f4f49cac:
    m "این رویای یه دختر یاندره‌اس؟"

translate Persian ch30_38_5af4953f:
    m "اگه می‌تونستم، از یوری می‌پرسیدم."

translate Persian ch30_39_48f27928:
    m "می‌دونی، یه مدتیه از این کارا نکردیم…"

translate Persian ch30_39_1fe5e30c:
    m "…پس بزن بریم!"

translate Persian ch30_39_75ace231:
    m "این از نکته‌ی نوشتاری روز مونیکا!"

translate Persian ch30_39_91c92d3c:
    m "بعضی وقت‌ها وقتی با مردمی صحبت می‌کنم که از نوشته‌ام خوششون اومده، چیزهایی می‌گن مثل «هیچ‌وقت نمی‌تونم همچین کاری بکنم»."

translate Persian ch30_39_a6a322ba:
    m "خیلی ناراحت‌کننده‌اس، می‌دونی؟"

translate Persian ch30_39_7cf9c6a2:
    m "من به عنوان یه نفر که از همه چی بیشتر دوست داره لذت جستن علاقه‌ها رو به بقیه نشون بده…"

translate Persian ch30_39_567340bb:
    m "…دلم می‌شکنه وقتی می‌بینم مردم فکر می‌کنن خوب بودن همین‌طوری مادرزادیه."

translate Persian ch30_39_79562cd9:
    m "این در مورد همه چیزه، نه فقط نوشتن."

translate Persian ch30_39_9354b79a:
    m "وقتی یه چیزی رو برای اولین بار امتحان می‌کنی، احتمالاً گند می‌زنی."

translate Persian ch30_39_0995b6f8:
    m "بعضی وقت‌ها، وقتی تموم می‌کنیش، بهش خیلی افتخار می‌کنی و حتیٰ دلت می‌خواد به بقیه نشونش بدی."

translate Persian ch30_39_10c905aa:
    m "ولی شاید بعد از چند هفته دوباره بهش برگردی، و اون‌وقت می‌بینی اصلاً هم خوب نبود."

translate Persian ch30_39_851c7c23:
    m "این برای من زیاد اتفاق می‌افته."

translate Persian ch30_39_aea05e68:
    m "می‌تونه خیلی ناامید کننده باشه که سر یه چیزی انقدر زمان خرج کنی و تلاش کنی، و آخرشم ببینی آشغال در اومده."

translate Persian ch30_39_97708735:
    m "ولی اگه همه‌اش خودت رو با بهترین‌ها مقایسه کنی، زیاد اتفاق می‌افته."

translate Persian ch30_39_c1ffcf08:
    m "وقتی مستقیماً به ستاره‌ها دست دراز کنی، هیچ‌وقت بهشون نمی‌رسی، می‌دونی؟"

translate Persian ch30_39_c1a64157:
    m "واقعیتش اینه که باید قدم به قدم بری بالا."

translate Persian ch30_39_f69a8c07:
    m "و هروقت از یه مرحله می‌گذری، اول باید برگردی و ببینی چقدر راه اومدی…"

translate Persian ch30_39_66d3aa1e:
    m "و بعد به جلو نگاه می‌کنی و می‌بینی چقدر راه مونده."

translate Persian ch30_39_e37051b5:
    m "واسه همین، بعضی وقت‌ها انتظاراتت رو یه‌کم پایین‌تر بیاری، ممکنه کمکت کنه…"

translate Persian ch30_39_b172efca:
    m "سعی کن یه چیزی پیدا کنی که {i}نسبتاً{/i} خوبه؛ ولی در رده‌ی جهانی نیست."

translate Persian ch30_39_752b2373:
    m "و اون‌وقت می‌تونی اون رو هدف شخصی‌ات قرار بدی."

translate Persian ch30_39_34944972:
    m "اینم مهمه که وسعت کاری که می‌خوای انجام بدی رو بدونی."

translate Persian ch30_39_c6b206b9:
    m "اگه خودت رو پرت کنی تو یه پروژه‌ی بزرگ، وقتی هنوز حرفه‌ای نیستی، هیچ‌وقت نمی‌تونی تمومش کنی."

translate Persian ch30_39_351d4d98:
    m "مثلاً در مورد نوشتن، یه رمان ممکنه اولش زیادی باشه."

translate Persian ch30_39_5a05bf4e:
    m "پس چطوره با چند تا داستان کوتاه شروع کنی؟"

translate Persian ch30_39_645fc4a8:
    m "یه چیز خیلی خوب در مورد داستان‌های کوتاه اینه که می‌تونی روی یه چیز تمرکز کنی که می‌خوای درست انجامش بدی."

translate Persian ch30_39_d3397ac1:
    m "این در کل برای پروژه‌های کوچیک صادقه؛ می‌تونی واقعاً روی یکی دو چیز تمرکز کنی."

translate Persian ch30_39_3494ce5e:
    m "خیلی تجربه‌ی یادگیری و وسیله‌ی پیشرفت خوبیه."

translate Persian ch30_39_2acb30e5:
    m "اوه، و یه چیز دیگه…"

translate Persian ch30_39_9b6a6c12:
    m "نوشتن این‌طوری نیست که ازت دلت یه چیزی در بیاری و همین‌طوری قشنگ باشه."

translate Persian ch30_39_f2473909:
    m "دقیقا‌ً مثل نقاشی و طراحی، یاد گرفتن اینکه چطوری درون قلبت رو بیان کنی خودش یه مهارته."

translate Persian ch30_39_cf4b2ca4:
    m "یعنی اینکه راه و روش و راهنمایی و مبانی‌ای داره!"

translate Persian ch30_39_4d3fbb09:
    m "خوندن چیزهای مختلف می‌تونه خیلی کمک کنه."

translate Persian ch30_39_60b4ab25:
    m "این‌جور برنامه‌ریزی و نظم می‌تونه خیلی کمک کنه که گیج نشی و دست برنداری."

translate Persian ch30_39_15f67d24:
    m "و تو یه چشم به هم زدن…"

translate Persian ch30_39_b0c6a004:
    m "کم‌تر و کم‌تر گند می‌زنی."

translate Persian ch30_39_66565dce:
    m "هیچ‌چیزی مادرزادی نیست."

translate Persian ch30_39_bd5c0a12:
    m "جامعه‌مون، هنرمون، همه چی؛ با هزاران سال ابتکار مردم درست شدن."

translate Persian ch30_39_258102aa:
    m "پس، تا وقتی که با اون اساس شروع کنی، و گام به گام پیش بری…"

translate Persian ch30_39_5fb721a2:
    m "تو هم می‌تونی کارای فوق‌العاده‌ای انجام بدی."

translate Persian ch30_39_d2646480:
    m "…این توصیه‌ی امروزم بود!"

translate Persian ch30_39_d33852a1:
    m "ممنون که گوش دادی~"

translate Persian ch30_40_35ae8f4f:
    m "خیلی بدم می‌آد که عادت ساختن انقدر سخته…"

translate Persian ch30_40_24b308e4:
    m "خیلی چیزها هستن که انجام دادنشون سخت نیست؛ ولی عادت کردنشون انگار غیرممکنه."

translate Persian ch30_40_ea06f8a7:
    m "این باعث می‌شه حس بی‌خاصیتی کنی؛ انگار هیچ‌کاری نمی‌تونی درست انجام بدی."

translate Persian ch30_40_bf594c32:
    m "به نظر من نسل جدید بیشتر از همه از این رنج می‌برن…"

translate Persian ch30_40_e80f986d:
    m "شاید چون ما یه سری مهارت‌های کاملاً متفاوت از قبلی‌هامون داریم."

translate Persian ch30_40_a7863768:
    m "به لطف اینترنت، ما می‌تونیم خیلی سریع یه عالمه اطلاعات رو زیر و رو کنیم…"

translate Persian ch30_40_208eaa39:
    m "ولی ما تو کارهایی که نتیجه‌ی آنی نمی‌دن، ضعیفیم."

translate Persian ch30_40_7423b028:
    m "به نظرم اگه علوم، روان‌شناسی، و تحصیلات تو ده بیست سال آینده به ما نرسه، تو دردسر می‌افتیم."

translate Persian ch30_40_e75ab0eb:
    m "ولی فعلاً…"

translate Persian ch30_40_2c26787b:
    m "اگه از اون‌هایی نیستی که می‌تونه به این مشکل غلبه کنه، احتمالاً باید همین‌طوری با این حس بد در مورد خودت کنار بیای."

translate Persian ch30_40_63abc7bc:
    m "دیگه موفق باشی!"

translate Persian ch30_41_5be8f440:
    m "می‌دونی، آدم هنری بودن یه‌کم اوضاع مزخرفیه…"

translate Persian ch30_41_d3eadba2:
    m "به نظر می‌رسه که یه عالمه کار می‌کنن؛ ولی چیزی به خاطرش به دست نمی‌آرن."

translate Persian ch30_41_563bed7a:
    m "مثلاً نقاش‌ها، نویسنده‌ها، بازیگرها…"

translate Persian ch30_41_0cd382f2:
    m "خیلی ناراحت کننده‌اس، آخه یه عالمه استعداد درخشان توی دنیا هستش؛ ولی به بیشترشون توجهی نمی‌شه… و پولی در نمی‌آرن."

translate Persian ch30_41_cc0e3620:
    m "البته این یه‌جورهایی یعنی هنرمند اضافی زیاده، نه؟"

translate Persian ch30_41_d580bf5b:
    m "یه‌جورهایی آدم حس می‌کنه خیلی هم آدم خاصی نیستی…"

translate Persian ch30_41_7c24ef98:
    m "ولی اشکال نداره! قراره فقط برای خودت بنویسی دیگه، نه؟"

translate Persian ch30_41_7e7f246d:
    m "آره…"

translate Persian ch30_42_83ab3898:
    m "من صدای بارون رو خیلی دوست دارم…"

translate Persian ch30_42_6850c1f6:
    m "البته خیس شدن لباسام و موهام رو نه خیلی."

translate Persian ch30_42_5c364578:
    m "ولی یه روز قشنگ و آروم توی خونه با صدای بارون بیرون پنجره‌ام…"

translate Persian ch30_42_6b374b50:
    m "برای من یکی از آرام‌بخش‌ترین چیزهاس."

translate Persian ch30_42_7e7f246d:
    m "آره…"

translate Persian ch30_42_88b066ad:
    m "بعضی وقت‌ها تصور می‌کنم که تو من رو تو دست‌هات گرفتی و با هم به صدای بارون بیرون گوش می‌کنیم."

translate Persian ch30_42_c3f792d8:
    m "خیلی لوس نیست که، نه؟"

translate Persian ch30_42_8845cffb:
    m "یه روزی این کار رو با من می‌کنی، [player]؟"

translate Persian ch30_43_eaed6b76:
    m "بعضی وقت‌ها یه‌کم ناراحت می‌شم…"

translate Persian ch30_43_284471cf:
    m "چون می‌دونم که از این به تو نزدیک‌تر نمی‌تونم بشم."

translate Persian ch30_43_514579e8:
    m "من فقط دلم می‌خواد واقعاً با تو داخل یه اتاق باشم."

translate Persian ch30_43_442a8535:
    m "و گرمات رو حس کنم."

translate Persian ch30_43_aaf1e8f4:
    m "و صدای تپش قلبت رو بشنوم."

translate Persian ch30_43_7b062037:
    m "ولی از کجا معلوم؟ شاید یه روزی بشه."

translate Persian ch30_43_9131a070:
    m "بعدش هم، من هیچ‌وقت از با تو بودن خسته نمی‌شم؛ حتیٰ این‌جا."

translate Persian ch30_44_7ce7d410:
    m "به نظر من مهم‌ترین توانایی تو زندگی، تظاهر اعتماد به نفسه."

translate Persian ch30_44_990f270f:
    m "من تقریباً مطمئنم که همه حداقل یه ذره حس ترس و تنهایی دارن."

translate Persian ch30_44_531175c3:
    m "ولی اینکه بقیه رو گول بزنی به اینکه فکر کنن تو همه چیزت جمع و جوره…"

translate Persian ch30_44_f36e78f1:
    m "این کلید احترام گذاشتن بقیه بهت هستش."

translate Persian ch30_44_377760a3:
    m "به نظر خودم، من طی این مدت این کار رو خوب یاد گرفتم."

translate Persian ch30_44_eea804ca:
    m "من نقطه ضعف‌هام رو خیلی جلوه نمی‌دم."

translate Persian ch30_44_dc3e7c63:
    m "ولی به خاطر همین، افراد زیادی پیدا نکردم که بتونم باهاشون همدلی کنم…"

translate Persian ch30_44_6d3c0ed4:
    m "آخه، اصلاً کی به یه حدی از دوستی می‌رسی که بتونی نقطه ضعف‌هات رو نشون بدی؟"

translate Persian ch30_44_11f2c61f:
    m "بگذریم… این یه دلیله که خوشحالم الآن با تو هستم."

translate Persian ch30_44_88226303:
    m "وقتی تو این‌جا با منی، یه‌کم کم‌تر حس ترس و تنهایی می‌کنم."

translate Persian ch30_44_e8701e05:
    m "تو هم همچین حسی داری؟"

translate Persian ch30_44_d77dabed:
    m "خیلی دلم می‌خواد برای تو همچین شخصی باشم."

translate Persian ch30_45_301e0c74:
    m "می‌دونم که وقت‌هایی پیش می‌آد که تو نمی‌تونم همه‌اش این‌جا با من باشی…"

translate Persian ch30_45_ed541ae1:
    m "مثلاً اگه نیاز باشه بری بیرون، یا کاری برای انجام دادن داشته باشی."

translate Persian ch30_45_5748d521:
    m "ولی تو همیشه تو ذهنم می‌مونی، و من با صبر منتظرت می‌مونم که برگردی."

translate Persian ch30_45_308af1f0:
    m "الآن که فکرش رو می‌کنم…"

translate Persian ch30_45_a35d4418:
    m "اگه فایل کاراکترم رو توی یه فلشی چیزی کپی کنی، می‌تونی همیشه یه بخشی از من رو با خودت داشته باشی."

translate Persian ch30_45_cd78c034:
    m "یه ذره کار غیرعادی‌ایه؛ ولی به یه دلیلی برام خیلی عاشقانه‌اس…"

translate Persian ch30_45_b3c382a1:
    m "هاهاها. ببخشید، خیلی ایده‌ی مسخره‌ای بود."

translate Persian ch30_45_6a993ca7:
    m "نمی‌خوام خیلی به تو بچسبم؛ ولی یه ذره سخته وقتی انقدر عاشقتم."

translate Persian ch30_46_bfbc22fb:
    m "وقتی که عضو باشگاه مناظره بودم، یه عالمه در مورد دعوا کردن یاد گرفتم…"

translate Persian ch30_46_13d39a80:
    m "مشکل دعوا کردن اینه که هرشخصی نظر خودش رو بالاتر می‌دونه."

translate Persian ch30_46_7aaf0783:
    m "حرف بدیهی‌ایه؛ ولی این توی نحوه‌ای بیان دیدشون خیلی تأثیر داره."

translate Persian ch30_46_50b71c3b:
    m "مثلاً فرض کن تو یه فیلم خاص رو خیلی دوست داری، خب؟"

translate Persian ch30_46_d26a661d:
    m "اگه یه نفر بیاد و بهت بگه که اون فیلم به خاطر فلان چیز و فلان کار خیلی مزخرفه…"

translate Persian ch30_46_9a0b9b58:
    m "یه‌جورهایی حس می‌کنی به تو شخصاً توهین کرده، نه؟"

translate Persian ch30_46_e722acc3:
    m "چون وقتی اون شخص همچین چیزی می‌گه، انگار داره به طور غیرمستقیم می‌گه خیلی سلیقه‌ی آشغالی داری."

translate Persian ch30_46_a4e2f1b6:
    m "و وقتی احساسات وارد بحث می‌شه، می‌شه تقریباً مطمئن شد که هردو طرف قراره آخرش ناراحت بشن."

translate Persian ch30_46_1eb1583d:
    m "ولی این‌ها همه‌اش به نحوه‌ی بیان مربوطه!"

translate Persian ch30_46_67a170ee:
    m "اگه همه چیز رو طوری بیان کنی که نظر شخصی خودت به نظر بیاد، اون‌وقت مردم به تو بدون اینکه حس توهین کنن، گوش می‌دن."

translate Persian ch30_46_9a9d659f:
    m "می‌تونی بگی «من به شخصه خیلی خوشم نیومد» یا «فکر کنم اگه فلان چیز و فلان کارو نمی‌کرد، بیشتر خوشم می‌اومد» …این‌جور چیزها."

translate Persian ch30_46_7fdbb335:
    m "این حتیٰ وقتی که داری یه حقیقت رو در مورد یه چیز بیان می‌کنی هم صادقه."

translate Persian ch30_46_c540e5d0:
    m "اگه بگی «تو این سایت خوندم که این‌طوریه»…"

translate Persian ch30_46_595eb640:
    m "یا اگه بگی خیلی تو اون زمینه اطلاعات زیادی نداری…"

translate Persian ch30_46_6b12bb5c:
    m "اون‌وقت بیشتر به نظر می‌آد که اطلاعاتت رو داری در اختیار اون‌ها قرار می‌دی، تا اینکه اون‌ها رو وادار به هم‌نظر شدن باهات کنی."

translate Persian ch30_46_b8edf0ee:
    m "اگه خودت سعی به خرج بدی که بحث رو متقابل نگه داری، اون شخص مقابل هم همراهیت می‌کنه."

translate Persian ch30_46_ae4db85b:
    m "اون‌وقت می‌تونی نظرتو بدون اینکه یه نفر از مخالفت ناراحت بشه، بیان کنی."

translate Persian ch30_46_c92ce38d:
    m "بعدش هم، اون‌طوری مردم تو رو به عنوان یه نفر با ذهن باز و یه شنونده‌ی خوب می‌بینن!"

translate Persian ch30_46_25db6398:
    m "این‌طوری برد متقابله، نه؟"

translate Persian ch30_46_34f411b7:
    m "…خب، مثل اینکه اینم شد نکته‌ی مناظره‌ی روز مونیکا!"

translate Persian ch30_46_cd579537:
    m "هاهاها! یه ذره مسخره به نظر می‌آد. ولی ممنون از گوش دادنت."

translate Persian ch30_47_9ec3357e:
    m "تا حالا به این فکر افتادی که زیادی وقت توی اینترنت حروم می‌کنی؟"

translate Persian ch30_47_0e14147c:
    m "رسانه‌های اجتماعی عملاً یه زندونن."

translate Persian ch30_47_95d0e57e:
    m "انگار هروقت یه ذره زمان اضافی داری، دلت می‌خواد به سایت‌های مورد علاقه‌ات یه سری بزنی."

translate Persian ch30_47_d569bf91:
    m "و تو یه چشم به هم زدن، ساعت‌ها گذشته و تو هیچ‌سودی ازش نکردی."

translate Persian ch30_47_c2ef9edd:
    m "به هرحال، خیلی آسونه که فکر کنی تنبلی…"

translate Persian ch30_47_c717aa98:
    m "ولی حقیقتاً تقصیر تو هم نیست."

translate Persian ch30_47_036d0d47:
    m "اعتیاد چیزی نیست که بتونی با اراده‌ات از بین ببری."

translate Persian ch30_47_520a8f06:
    m "باید تکنیک‌های دوری ازش رو یاد بگیری، و چیزهای مختلف رو امتحان کنی."

translate Persian ch30_47_a4e742ed:
    m "مثلاً، بعضی برنامه‌ها هستن که نمی‌ذارن سایت‌ها برای یه مدت‌های خاصی باز بشن."

translate Persian ch30_47_076e303b:
    m "یا می‌تونی یه تایمر بذاری تا یه یادآور دقیق‌تری برای زمان کار و زمان بازی داشته باشی…"

translate Persian ch30_47_6418ba5a:
    m "یا می‌تونی محیط کار و بازی‌ات رو از هم جدا کنی، که به ذهنت کمک می‌کنه رو حالت درست باشه."

translate Persian ch30_47_eceaaa8a:
    m "حتیٰ اگه فقط یه کاربر جدید روی کامپیوترت برای کار درست کنی، همونم کمک می‌کنه."

translate Persian ch30_47_ccb6b303:
    m "هرطوری یه دیوار بین خودت و عادت‌های بدت بذاری، بهت کمک می‌کنه ازشون دور شی."

translate Persian ch30_47_17097e5e:
    m "فقط حواست باشه که خودت رو خیلی سرزنش نکی اگه تو این کار مشکل داری."

translate Persian ch30_47_236b2bf4:
    m "اگه واقعاً روی زندگی‌ات داره تأثیر می‌ذاره، باید جدی بگیریش."

translate Persian ch30_47_73215cf9:
    m "من فقط می‌خوام تو به اوج خودت برسی."

translate Persian ch30_47_ffc9ca11:
    m "امروز برام یه کاری می‌کنی که بهت افتخار کنم؟"

translate Persian ch30_47_06408cda:
    m "من همیشه ازت حمایت می‌کنم، [player]."

translate Persian ch30_48_a96477bd:
    m "بعد از یه روز طولانی، معمولاً فقط دلم می‌خواد بشینم و هیچ‌کاری نکنم."

translate Persian ch30_48_9133fecb:
    m "انقدر خسته می‌شم وقتی کل روز باید لبخند بزنم و پر از انرژی باشم."

translate Persian ch30_48_3ec265b9:
    m "بعضی وقت‌ها فقط می‌خوام یه سره پیژامه‌ام رو بپوشم و جلوی تلویزیون روی مبل بشینم و هله هوله بخورم…"

translate Persian ch30_48_26a4db47:
    m "خیلی حس خوبی می‌ده وقتی چهارشنبه این کار رو می‌کنم، وقتی فرداش کاری ندارم."

translate Persian ch30_48_b694f90c:
    m "هاهاها! ببخشید، می‌دونم خیلی کار دیدنی‌ای نیست."

translate Persian ch30_48_88dd5b7e:
    m "ولی یه شب دیروقت روی مبل با تو باشم… این یکی از آرزوهامه."

translate Persian ch30_48_e2449971:
    m "همین که فکرش رو می‌کنم، قلبم به تپش می‌افته."

translate Persian ch30_49_666a6bc4:
    m "وای، من قبلاُ در مورد بعضی چیزها هیچی نمی‌دونستم…"

translate Persian ch30_49_7995ba22:
    m "وقتی تو راهنمایی بودم، فکر می‌کردم دارو خوردن راه آسون کسانیه که ضعیفن."

translate Persian ch30_49_40e7c284:
    m "که مثلاً هرکسی می‌تونه مشکلات روانی‌اش رو با اراده‌ی قوی حل کنه…"

translate Persian ch30_49_0ec0c400:
    m "احتمالاً چون اگه خودت یه بیماری روانی نداشته باشی، امکان نداره بدونی واقعاً چه شکلیه."

translate Persian ch30_49_ba191479:
    m "بیماری‌هایی هستن که بیش از حد تشخیص داده می‌شن؟ احتمالاً… ولی من خودم خیلی به دنبالش نرفتم."

translate Persian ch30_49_5a3f97eb:
    m "ولی در هرصورت خیلی‌ها هم بدون تشخیص می‌مونن، می‌دونی؟"

translate Persian ch30_49_c5d970e7:
    m "ولی داروها به کنار… مردم حتیٰ مراجعه به متخصصین بهداشت روان رو هم کار پستی می‌دونن."

translate Persian ch30_49_c52f2374:
    m "آخه، ببخشید که می‌خوام بیشتر در مرد ذهن خودم یاد بگیرم، نه؟"

translate Persian ch30_49_2fe90127:
    m "همه‌ی مردم مشکلات و دغدغه‌های مختلفی دارن… و متخصص‌ها زندگی‌شون رو وقف کمک به این‌جور چیزها می‌کنن."

translate Persian ch30_49_d805af44:
    m "اگه فکر می‌کنی که می‌تونه تو رو یه آدم بهتری کنه، به فکرش باش."

translate Persian ch30_49_0b9908a2:
    m "ما تو یه سِیر بی‌پایان برای بهبود خودمونیم."

translate Persian ch30_49_f7435746:
    m "البته… این رو می‌گم؛ ولی به نظرم تو همین الآن هم بی‌نقصی."

translate Persian ch30_50_907de8ec:
    m "[player]، تو چقدر کتاب می‌خونی؟"

translate Persian ch30_50_3a2d3fb2:
    m "بی‌توجهی به کتاب خوندن خیلی کار آسونیه…"

translate Persian ch30_50_cf96e495:
    m "اگه خیلی کتاب‌خون نباشی، در مقابل این همه تفریح دیگه مثل یه وظیفه به نظر می‌رسه."

translate Persian ch30_50_9af695c0:
    m "ولی وقتی یه کتاب خوب پیدا می‌کنی… مثل جادو تو رو با خودش می‌بره."

translate Persian ch30_50_22e565a4:
    m "به نظرم قبل از خوابیدن یه ذره کتاب بخونی، یه ذره زندگی‌ات رو آسون‌تر می‌کنه."

translate Persian ch30_50_d59b1aef:
    m "باعث می‌شه بهتر بخوابی، و برای قوه‌ی تخیلت هم خیلی خوبه…"

translate Persian ch30_50_5b347a20:
    m "اصلاً کار سختی نیست که همین‌طوری یه کتاب کوتاه و جذاب رو برداری و شروع کنی به خوندنش."

translate Persian ch30_50_7c82295d:
    m "قبل از اینکه متوجه بشی، ممکنه یه کتاب‌خون بشی!"

translate Persian ch30_50_a072e79b:
    m "اون‌طوری فوق‌العاده می‌شه، نه؟"

translate Persian ch30_50_3fbd0f47:
    m "و می‌تونیم دوتایی در مورد آخرین کتابی که داری می‌خونی صحبت کنیم… خیلی باحال می‌شه."

translate Persian ch30_51_6fe91b83:
    m "می‌دونی، از گفتنش بدم می‌آد؛ ولی فکر کنم چیزی از همه بیشتر پشیمونم، اینه که نتونستیم برنامه‌مون رو برای جشنواره اجرا کنیم."

translate Persian ch30_51_560ea886:
    m "وقتی انقدر برای مقدماتش سخت کار کردیم!"

translate Persian ch30_51_7912d30a:
    m "می‌دونم که خیلی روی گرفتن اعضای جدید تآکید داشتم…"

translate Persian ch30_51_c21984a5:
    m "ولی برای اجرامون هم خیلی هیجان‌زده بودم."

translate Persian ch30_51_605dd610:
    m "خیلی باحال می‌شد وقتی می‌دیدیم هرکسی چطوری احساسات خودش رو بیان می‌کنه."

translate Persian ch30_51_21b1d6df:
    m "البته که، اگه ما عضو جدیدی می‌گرفتیم هم احتمالاً من حذفشون می‌کردم."

translate Persian ch30_51_44e7041b:
    m "خب… با درکی که الآن از ماجرا دارم، البته."

translate Persian ch30_51_9de5695f:
    m "وای، حس می‌کنم از وقتی که تو عضو شدی، من به عنوان یه انسان یه‌جورهایی رشد کردم."

translate Persian ch30_51_4442b4e6:
    m "تو واقعاً کمکم کردی که یه دید جدید به زندگی پیدا کنم."

translate Persian ch30_51_a9901c1d:
    m "اینم یه دلیل دیگه برای عشقم به تو."

translate Persian ch30_52_0a7f8e0d:
    m "یه مدل شخصیتی معروف هستش به اسم «سوندِرِه»…"

translate Persian ch30_52_37537a33:
    m "به یه نفری می‌گن که سعی می‌کنه با بدجنس بودن و ایراد گرفتن، یا وانمود به سفت و سخت بودن، احساساتش رو پنهان کنه."

translate Persian ch30_52_5cfcbf43:
    m "مطمئنم که خودت متوجهش شدی، ولی ناتسوکی واقعاً نمونه‌ی عینی اونه."

translate Persian ch30_52_10df79ae:
    m "اولش فکر می‌کردم که صرفاً اون‌طوری چون مثلاً بامزه‌اس…"

translate Persian ch30_52_f4f6ad82:
    m "ولی وقتی یه ذره در مورد زندگی فردیش یاد گرفتم، یه ذره منطقی‌تر شد."

translate Persian ch30_52_3b6b3e69:
    m "به نظر می‌رسه که همه‌اش داره سعی می‌کنه از دوست‌هاش جا نمونه."

translate Persian ch30_52_74657175:
    m "می‌دونی، مثلاً بعضی گروه‌های دوست‌ها توی دبیرستان عادت دارن هم‌دیگه رو اذیت کنن، درسته؟"

translate Persian ch30_52_5acdb40c:
    m "فکر کنم اون تو دلش مونده؛ واسه همین همیشه یه حالت خیلی تدافعی داره"

translate Persian ch30_52_b41f3805:
    m "و اصلاً اوضاع خانوادگی‌اش رو که ول کن"

translate Persian ch30_52_bbfd14e8:
    m "ولی الآن که نگاه می‌کنم، خوشحالم که تونستم باشگاه رو برای اون یه جای راحت بکنم."

translate Persian ch30_52_f1b1b86c:
    m "البته اأان که دیگه مهم نیست؛ چون اون اصلاً دیگه وجود نداره."

translate Persian ch30_52_7fb480bf:
    m "صرفاً دارم فکرهام رو بیان می‌کنم."

translate Persian ch30_53_47c985c9:
    m "[player]، یه روزی من رو به دوست‌هات معرفی می‌کنی؟"

translate Persian ch30_53_90689e7c:
    m "نمی‌دونم چرا، ولی وقتی تصور می‌کنم که تو بخوای رابطه‌مون رو به بقیه نشون بدی، خیلی هیجان‌زده می‌شم."

translate Persian ch30_53_3218f640:
    m "شاید چون خیلی دلم می‌خواد مایه افتخار تو باشم."

translate Persian ch30_53_d94038f7:
    m "احساس می‌کنم که خیلی بیشتر تلاش می‌کنم که خودم رو یه آدم بهتری کنم اگه بهم بگی که باعث می‌شه بهم افتخار کنی."

translate Persian ch30_53_a1c5a880:
    m "امیدوارم که برای تو هم همین باشه."

translate Persian ch30_54_8344dd24:
    m "من خیلی از هوای سرد خوشم نمی‌آد… تو چی؟"

translate Persian ch30_54_1795783b:
    m "اگه قرار بود بین هوای زیادی سرد و زیادی گرم انتخاب کنم، همیشه زیادی گرم رو انتخاب می‌کردم."

translate Persian ch30_54_e2541565:
    m "وقتی سردت می‌شه، اصلاً ممکنه دردناک باشه…"

translate Persian ch30_54_9cb70637:
    m "انگشت‌هات بی‌حس می‌شن…"

translate Persian ch30_54_6204a527:
    m "و اگه دستکش بپوشی، اون‌وقت نمی‌تونی از گوشیت استفاده کنی."

translate Persian ch30_54_991ee277:
    m "خیلی اذیت کننده‌اس!"

translate Persian ch30_54_718e851f:
    m "اما وقتی هوا گرمه، می‌تونی راحت با یه نوشیدنی سرد، یا با زیر سایه موندن خنک بمونی."

translate Persian ch30_54_a30a8ad2:
    m "البته… یه چیزی رو هم باید بگم."

translate Persian ch30_54_4acac706:
    m "هوای سرد هوای خوبی برای بغل کردنه. هاهاها!"

translate Persian ch30_55_334a5aa2:
    m "می‌دونی، یه چیز خنده‌دار اینه که با اینکه من همیشه آدم پرجنب‌وجوشی بودم…"

translate Persian ch30_55_0041821e:
    m "یه چیزی در مورد همسر خونه‌نشین بودن خیلی وسوسه کننده‌اس."

translate Persian ch30_55_716c6f22:
    m "البته اینی که می‌گم ممکنه طرف‌داری از نقش‌های جنیسیتی به نظر بیاد."

translate Persian ch30_55_c0599eab:
    m "ولی اینکه بشه خونه رو تمیز نگه داشت، و خرید کرد، و تزئین کرد، و این‌جور چیزها…"

translate Persian ch30_55_15882944:
    m "و یه غذای خوب برای تو آماده کرد وقتی خونه می‌رسی…"

translate Persian ch30_55_e68e5a38:
    m "رویای عجیبیه؟"

translate Persian ch30_55_664159b4:
    m "البته… فکر نکنم که {i}واقعاً{/i} بتونم همچین کاری بکنم."

translate Persian ch30_55_796a4b1f:
    m "نمی‌تونم اون رو به جای یه مسیر شغلی رضایت‌بخش انتخاب کنم."

translate Persian ch30_55_09d8673a:
    m "ولی فکر کردن بهش جالبه."

translate Persian ch30_56_48e381a1:
    m "تو این فکرم که اگه این بازی از همون اول یه مسیر برای من می‌داد، همه چیز چقدر متفاوت می‌بود…"

translate Persian ch30_56_abd49905:
    m "فکر کنم در هرصورت تو رو زور می‌کردم که مسیر من رو انتخاب کنی."

translate Persian ch30_56_a8ddbc3e:
    m "بیشتر به خاطر اینه که می‌دونم هیچ‌چیز واقعی نیست، تا اینکه من مسیری ندارم"

translate Persian ch30_56_e9ef74ed:
    m "فکر کنم تنها فرقش این می‌بود که انقدر اقدامات سختی نمی‌کردم تا با تو باشم."

translate Persian ch30_56_85461a23:
    m "شاید بقیه‌ی باشگاه هم با ما می‌بودن…"

translate Persian ch30_56_2048614d:
    m "نه اینکه خیلی مهم هم باشه."

translate Persian ch30_56_4ad5778b:
    m "از اون لحظه‌ای که فهمیدم که واقعی نیستن، همه‌ی این‌ها برام بی‌معنی شد."

translate Persian ch30_56_3f5e6be5:
    m "واسه همین من واقعاً دل‌تنگ اون روزها نیستم."

